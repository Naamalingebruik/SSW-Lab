# ============================================================
# SSW-Lab | config.local.ps1  (PERSOONLIJK — staat in .gitignore)
# ============================================================
# Kopieer dit bestand naar config.local.ps1 en vul jouw waarden in.
# Nooit committen naar git.
# ============================================================

# Laad eerst de basis config
$configBase = "$PSScriptRoot\config.ps1"
if (Test-Path $configBase) { . $configBase }

# Overschrijf of vul aan met jouw lokale waarden:
# Gebruik voor wachtwoorden bij voorkeur SecretManagement of environment variables:
#   setx SSW_LAB_PASSWORD "VervangDitMetJouwLabWachtwoord"
#   setx SSW_DSRM_PASSWORD "VervangDitMetJouwDsrmWachtwoord"
# Alleen als tijdelijke fallback kun je lokaal een wachtwoord in config.local.ps1 zetten.
# $SSWConfig.LabPassword = 'VervangDitMetJouwLabWachtwoord'
$SSWConfig.EntraUPN    = 'jouwdomein.nl'                   # Bijv. lab.stts.nl

# Optioneel: andere paden als je VHDs ergens anders opslaat
# $SSWConfig.VMPath  = 'E:\VMs'
# $SSWConfig.ISOPath = 'E:\ISOs'
